---

---

<section id="servicios" class="py-24 bg-slate-900 relative overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">
    <!-- Encabezado -->
    <div data-animate data-animation="fade-in-up" class="opacity-0">
      <div class="text-center mb-12 sm:mb-16">
        <span
          class="inline-block text-xs font-semibold tracking-widest uppercase mb-4"
          style="color: #1D9E75;"
          data-i18n="services.badge"
        >
          Servicios
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
          <span data-i18n="services.title">Lo que</span>
          <span style="color: #1D9E75;" data-i18n="services.titleHighlight"
            >construyo</span
          >
        </h2>
        <p
          class="text-slate-400 max-w-xl mx-auto text-base sm:text-lg"
          data-i18n="services.subtitle"
        >
          Webs que trabajan por tu negocio, no solo ocupan espacio en internet.
        </p>
      </div>
    </div>

    <div class="flex flex-col gap-5">
      <!-- Card principal: Desarrollo Web -->
      <div
        data-animate
        data-animation="fade-in-up"
        class="opacity-0"
        style="animation-delay: 100ms;"
      >
        <div
          class="rounded-2xl border border-slate-700/60 bg-slate-800/50 p-8 sm:p-10 overflow-hidden"
        >
          <div class="flex flex-col lg:flex-row gap-10">
            <!-- Columna izquierda: texto -->
            <div class="flex-1 flex flex-col justify-between gap-6">
              <div>
                <span
                  class="inline-block text-xs font-semibold tracking-wider uppercase px-3 py-1 rounded-full border mb-5"
                  style="color: #1D9E75; border-color: #1D9E7540; background: #1D9E7510;"
                  data-i18n="services.main.badge"
                >
                  Servicio principal
                </span>
                <h3
                  class="text-2xl sm:text-3xl font-bold text-white mb-3 leading-snug"
                  data-i18n="services.main.title"
                >
                  Tu negocio merece una web que atraiga clientes
                </h3>
                <p
                  class="text-slate-400 leading-relaxed"
                  data-i18n="services.main.desc"
                >
                  Diseño y desarrollo sitios web rápidos, modernos y fáciles de
                  usar. Sin plantillas genéricas. Sin tecnicismos. Con
                  resultados reales.
                </p>
              </div>
              <div>
                <a
                  href="#proyectos"
                  class="inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-xl text-white transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5"
                  style="background-color: #1D9E75;"
                >
                  <span data-i18n="services.main.cta">Ver proyectos</span>
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Columna derecha: checklist -->
            <div
              class="lg:w-72 flex flex-col justify-center gap-4 rounded-xl p-6 bg-slate-700/30"
            >
              <div class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  style="color: #1D9E75;"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-white text-sm" data-i18n="services.main.c1"
                  >Entrega en 7 a 14 días hábiles</span
                >
              </div>
              <div class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  style="color: #1D9E75;"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-white text-sm" data-i18n="services.main.c2"
                  >Soporte incluido el primer mes</span
                >
              </div>
              <div class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  style="color: #1D9E75;"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-white text-sm" data-i18n="services.main.c3"
                  >Sin contratos largos ni letra chica</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Cards secundarias -->
      <div class="grid sm:grid-cols-2 gap-5">
        <!-- Integraciones -->
        <div
          data-animate
          data-animation="fade-in-up"
          class="opacity-0"
          style="animation-delay: 200ms;"
        >
          <div
            class="rounded-2xl border border-slate-700/60 bg-slate-800/50 p-7 h-full flex flex-col gap-4"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center"
              style="background: #1D9E7515; border: 1px solid #1D9E7540;"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                style="color: #1D9E75;"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                ></path>
              </svg>
            </div>
            <div>
              <h3
                class="text-lg font-bold text-white mb-2"
                data-i18n="services.int.title"
              >
                Integraciones
              </h3>
              <p
                class="text-slate-400 text-sm leading-relaxed"
                data-i18n="services.int.desc"
              >
                Conecto tu web con WhatsApp, reservas, pagos y las herramientas
                que ya usas en tu negocio.
              </p>
            </div>
            <p
              class="text-sm mt-auto pt-3 border-t border-slate-700/50 text-slate-500"
              data-i18n="services.int.detail"
            >
              Sin procesos manuales innecesarios
            </p>
          </div>
        </div>

        <!-- Mantención -->
        <div
          data-animate
          data-animation="fade-in-up"
          class="opacity-0"
          style="animation-delay: 300ms;"
        >
          <div
            class="rounded-2xl border border-slate-700/60 bg-slate-800/50 p-7 h-full flex flex-col gap-4"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center"
              style="background: #1D9E7515; border: 1px solid #1D9E7540;"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                style="color: #1D9E75;"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3
                class="text-lg font-bold text-white mb-2"
                data-i18n="services.maint.title"
              >
                Mantención
              </h3>
              <p
                class="text-slate-400 text-sm leading-relaxed"
                data-i18n="services.maint.desc"
              >
                Tu sitio siempre funcionando. Me encargo de actualizaciones,
                ajustes y soporte para que tú te enfoques en tu negocio.
              </p>
            </div>
            <p
              class="text-sm mt-auto pt-3 border-t border-slate-700/50 text-slate-400"
            >
              <span data-i18n="services.maint.prefix">Desde</span>
              <span
                class="font-semibold"
                style="color: #1D9E75;"
                data-i18n="services.maint.price">$50.000 / mes</span
              >
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA al fondo -->
    <div
      data-animate
      data-animation="fade-in-up"
      class="opacity-0 mt-14 text-center"
      style="animation-delay: 400ms;"
    >
      <p class="text-slate-500 text-sm">
        <span data-i18n="services.cta">¿No sabes por dónde empezar?</span>{" "}
        <a
          href="#contacto"
          class="transition-colors underline underline-offset-4 hover:opacity-80"
          style="color: #1D9E75;"
          data-i18n="services.ctaLink"
        >
          Conversemos →
        </a>
      </p>
    </div>
  </div>
</section>
