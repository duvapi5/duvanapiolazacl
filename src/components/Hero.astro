---
const whatsappNumber = "56942183179";
const whatsappMessage = encodeURIComponent(
  "Hola Duván, me gustaría conversar sobre un proyecto.",
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<section
  class="flex flex-col md:flex-row bg-slate-950 text-white overflow-hidden md:h-[100dvh]"
  id="hero"
>
  <!-- ====== PANEL IZQUIERDO: solo foto ====== -->
  <div
    class="hero-panel-left w-full md:w-[40%] h-[80vw] sm:h-[65vw] md:h-full overflow-hidden border-b md:border-b-0 md:border-r border-slate-800/50"
  >
    <img
      src="/yop.jpg"
      alt="Duván Apiolaza"
      class="hero-photo w-full h-full object-cover object-center"
      loading="eager"
    />
  </div>

  <!-- ====== PANEL DERECHO ====== -->
  <div
    class="relative w-full md:w-[60%] bg-slate-950 overflow-hidden flex flex-col justify-between p-6 sm:p-8 md:pt-10 md:pb-8 md:px-14 gap-8 md:gap-0"
  >
    <!-- Glow ambiental -->
    <div
      class="glow-orb absolute top-0 right-0 w-[500px] h-[500px] pointer-events-none"
      style="background: radial-gradient(ellipse at 80% 10%, rgba(29,158,117,0.08) 0%, transparent 70%);"
    >
    </div>

    <!-- ── BLOQUES 1+2 agrupados: propuesta de valor + métricas ── -->
    <div class="relative z-10 flex flex-col gap-5 md:gap-8">
      <!-- BLOQUE 1: eyebrow + título + bajada + CTAs -->
      <div class="animate-fade-in-up" style="animation-delay: 80ms;">
        <!-- Eyebrow -->
        <p
          class="text-xs font-mono tracking-[0.18em] text-slate-600 uppercase mb-4"
        >
          Portafolio · 2026
        </p>

        <!-- Título principal -->
        <h1
          class="text-3xl sm:text-4xl lg:text-[3.4rem] font-bold text-white leading-[1.05] tracking-tight mb-4 sm:mb-5"
          data-i18n="hero.title"
        >
          Webs que ayudan a<br />tu negocio a
          <span class="text-[#1D9E75] relative inline-block">
            crecer
            <svg
              class="underline-svg absolute -bottom-1 left-0 w-full"
              viewBox="0 0 200 8"
              preserveAspectRatio="none"
              aria-hidden="true"
            >
              <path
                d="M2 5 Q 50 1, 100 4 T 198 3"
                stroke="#1D9E75"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                opacity="0.45"></path>
            </svg>
          </span>
        </h1>

        <!-- Bajada: solo desktop -->
        <p
          class="hidden md:block text-slate-400 text-[0.95rem] leading-relaxed max-w-lg mb-7"
        >
          Diseño y desarrollo sitios web para negocios que necesitan algo más
          que presencia online: una web clara, rápida y pensada para generar
          confianza, contactos y ventas.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3">
          <!-- Principal -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary group inline-flex items-center gap-2.5
                 bg-[#1D9E75] hover:bg-[#188761] text-white font-semibold
                 px-6 py-3 rounded-lg text-sm transition-all duration-300
                 hover:shadow-lg hover:shadow-emerald-500/25 hover:-translate-y-0.5"
          >
            <svg
              class="w-4 h-4 flex-shrink-0 group-hover:scale-110 transition-transform"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Hablemos
            <svg
              class="w-3.5 h-3.5 opacity-70 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <!-- Secundario -->
          <a
            href="#proyectos"
            class="inline-flex items-center gap-2 text-slate-400 hover:text-white text-sm font-medium
                 border border-slate-800 hover:border-slate-600 px-5 py-3 rounded-lg
                 transition-all duration-300"
          >
            Ver proyectos
          </a>
        </div>
      </div>

      <!-- BLOQUE 2: métricas de confianza -->
      <div class="animate-fade-in-up" style="animation-delay: 220ms;">
        <div
          class="flex items-stretch gap-0 rounded-xl border border-slate-800/60 overflow-hidden text-sm sm:text-base"
        >
          <div
            class="flex-1 flex flex-col justify-center px-3 sm:px-5 py-3 sm:py-4 border-r border-slate-800/60"
          >
            <span
              class="metric-value text-[#1D9E75] font-bold text-base sm:text-lg leading-none mb-1"
              >+5</span
            >
            <span class="text-[10px] sm:text-xs text-slate-400 leading-snug"
              >proyectos en producción</span
            >
          </div>
          <div
            class="flex-1 flex flex-col justify-center px-3 sm:px-5 py-3 sm:py-4 border-r border-slate-800/60"
          >
            <span
              class="metric-value text-[#1D9E75] font-bold text-base sm:text-lg leading-none mb-1"
              >7–14</span
            >
            <span class="text-[10px] sm:text-xs text-slate-400 leading-snug"
              >días de entrega inicial</span
            >
          </div>
          <div
            class="flex-1 flex flex-col justify-center px-3 sm:px-5 py-3 sm:py-4"
          >
            <span
              class="metric-value text-[#1D9E75] font-bold text-base sm:text-lg leading-none mb-1"
              >1er mes</span
            >
            <span class="text-[10px] sm:text-xs text-slate-400 leading-snug"
              >soporte incluido</span
            >
          </div>
        </div>
      </div>
    </div>
    <!-- /wrapper bloques 1+2 -->

    <!-- ── BLOQUE 3: identidad + índice + redes ── -->
    <div
      class="relative z-10 animate-fade-in-up"
      style="animation-delay: 380ms; padding-top: 0.75rem;"
    >
      <!-- Watermark DA -->
      <div
        class="absolute bottom-0 right-0 text-[120px] font-black leading-none pointer-events-none select-none tracking-tighter"
        style="color: rgba(255,255,255,0.03);"
        aria-hidden="true"
      >
        DA
      </div>

      <!-- Nombre e identidad -->
      <p
        class="text-lg font-semibold text-white tracking-tight leading-none mb-1"
      >
        Duván Apiolaza
      </p>
      <p class="text-xs text-slate-500 mb-5">
        Desarrollador web · Co-founder de LowSystem · Remoto en Chile
      </p>

      <!-- Índice: solo desktop -->
      <div class="hidden md:flex items-center gap-3 mb-4">
        <span
          class="text-[10px] font-mono tracking-[0.18em] text-slate-700 uppercase"
          >Explora</span
        >
        <span class="h-px flex-1 bg-slate-800"></span>
      </div>
      <nav
        class="hidden md:flex flex-wrap items-center gap-x-5 gap-y-2 mb-4"
        aria-label="Secciones"
      >
        {
          [
            { label: "Servicios", href: "#servicios", num: "01" },
            { label: "Portafolio", href: "#proyectos", num: "02" },
            { label: "Metodología", href: "#proceso", num: "03" },
            { label: "Contacto", href: "#contacto", num: "04" },
          ].map(({ label, href, num }) => (
            <a
              href={href}
              class="neon-link group inline-flex items-baseline gap-1 text-slate-500 hover:text-[#1D9E75] transition-all duration-300"
            >
              <span class="text-[9px] font-mono text-slate-700 group-hover:text-[#1D9E75]/60 transition-colors">
                {num}
              </span>
              <span class="text-xs font-medium">{label}</span>
            </a>
          ))
        }
      </nav>

      <!-- Redes sociales -->
      <div class="flex items-center gap-0.5">
        <a
          href="https://instagram.com/duvanapiolaza.cl"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-600 hover:text-pink-400 hover:bg-slate-900 p-2 rounded-lg transition-all duration-300"
          aria-label="Instagram"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/duvan-apiolaza/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-600 hover:text-blue-400 hover:bg-slate-900 p-2 rounded-lg transition-all duration-300"
          aria-label="LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href="https://github.com/duvapi5"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-600 hover:text-white hover:bg-slate-900 p-2 rounded-lg transition-all duration-300"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Entrada panel izquierdo (solo desktop) ── */
  @media (min-width: 768px) {
    .hero-panel-left {
      animation: slideInLeft 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }
  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Zoom lento en la foto ── */
  .hero-photo {
    animation: zoomPhoto 12s ease-in-out infinite alternate;
  }
  @keyframes zoomPhoto {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.06);
    }
  }

  /* ── Fade-in-up para los bloques del panel derecho ── */
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Subrayado SVG trazado ── */
  .underline-svg path {
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    animation: drawLine 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
  }
  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* ── Glow orb: respiración ── */
  .glow-orb {
    animation: breatheGlow 6s ease-in-out infinite;
  }
  @keyframes breatheGlow {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.12);
    }
  }

  /* ── Métricas: count-up visual (slide-up del número) ── */
  .animate-fade-in-up .metric-value {
    display: inline-block;
    animation: metricPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s both;
  }
  @keyframes metricPop {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.85);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Neon en el índice ── */
  @keyframes neon-pulse {
    0%,
    100% {
      text-shadow: 0 0 4px rgba(29, 158, 117, 0);
    }
    50% {
      text-shadow:
        0 0 8px rgba(29, 158, 117, 0.6),
        0 0 16px rgba(29, 158, 117, 0.25);
    }
  }
  .neon-link:hover span:last-child {
    animation: neon-pulse 1.4s ease-in-out infinite;
    color: #1d9e75;
  }

  /* ── Botón principal: shimmer en hover ── */
  .btn-primary {
    position: relative;
    overflow: hidden;
  }
  .btn-primary::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.15) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0s;
  }
  .btn-primary:hover::after {
    transform: translateX(100%);
    transition: transform 0.5s ease;
  }
</style>
