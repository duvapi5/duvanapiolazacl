---
const whatsappNumber = "56942183179";
const whatsappMessage = encodeURIComponent(
  "Hola Duván, me gustaría conversar sobre un proyecto.",
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<section
  class="flex flex-col md:flex-row bg-slate-950 text-white overflow-hidden md:h-[100dvh]"
  id="hero"
>
  <!-- ====== PANEL IZQUIERDO: solo foto ====== -->
  <div
    class="hero-panel-left relative w-full md:w-[40%] h-[60vw] sm:h-[65vw] md:h-full overflow-hidden border-b md:border-b-0 md:border-r border-slate-800/50"
  >
    <img
      src="/yop.jpg"
      alt="Duván Apiolaza"
      class="hero-photo w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Vignette + transición al panel derecho -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse at 30% 40%, transparent 45%, rgba(2,6,23,0.55) 100%);"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 w-24 md:w-32"
      style="background: linear-gradient(to right, transparent, rgba(2,6,23,0.85));"
      aria-hidden="true"
    >
    </div>
  </div>

  <!-- ====== PANEL DERECHO ====== -->
  <div
    class="relative w-full md:w-[60%] flex flex-col justify-between p-5 sm:p-8 md:pt-12 md:pb-10 md:px-16 lg:px-20 xl:px-24 gap-6 md:gap-0"
    style="background: radial-gradient(ellipse at 100% 0%, rgba(29,158,117,0.07) 0%, transparent 55%), linear-gradient(180deg, #0b1424 0%, #050a17 100%);"
  >
    <!-- Glow ambiental -->
    <div
      class="glow-orb absolute top-0 right-0 w-[600px] h-[600px] pointer-events-none"
      style="background: radial-gradient(ellipse at 80% 10%, rgba(29,158,117,0.10) 0%, transparent 70%);"
    >
    </div>
    <!-- Grano sutil -->
    <div
      class="hero-noise pointer-events-none absolute inset-0 opacity-[0.035] mix-blend-overlay"
      aria-hidden="true"
    >
    </div>

    <!-- ── BLOQUES 1+2 agrupados: propuesta de valor + métricas ── -->
    <div class="relative z-10 flex flex-col gap-4 sm:gap-5 md:gap-8">
      <!-- BLOQUE 1: eyebrow + título + bajada + CTAs -->
      <div class="animate-fade-in-up" style="animation-delay: 80ms;">
        <!-- Eyebrow -->
        <p
          class="text-xs font-mono tracking-[0.18em] text-slate-600 uppercase mb-3 sm:mb-4"
        >
          Portafolio · 2026
        </p>

        <!-- Título principal -->
        <h1
          class="text-3xl sm:text-4xl lg:text-[3.6rem] xl:text-[4.25rem] font-bold text-white leading-[1.05] tracking-tight mb-4 sm:mb-6"
          data-i18n="hero.title"
        >
          Webs que ayudan a<br />tu negocio a
          <span class="text-[#1D9E75] relative inline-block">
            crecer
            <svg
              class="underline-svg absolute -bottom-1 left-0 w-full"
              viewBox="0 0 200 8"
              preserveAspectRatio="none"
              aria-hidden="true"
            >
              <path
                d="M2 5 Q 50 1, 100 4 T 198 3"
                stroke="#1D9E75"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                opacity="0.45"></path>
            </svg>
          </span>
        </h1>

        <!-- Bajada -->
        <p
          class="text-slate-400 text-sm sm:text-base lg:text-lg leading-relaxed max-w-md lg:max-w-lg mb-5 sm:mb-8"
        >
          Diseño y desarrollo sitios web para negocios que necesitan verse
          profesionales, generar confianza y convertir visitas en contactos y
          ventas.
        </p>

        <!-- CTAs -->
        <div class="flex items-center gap-2 sm:gap-3 flex-wrap sm:flex-nowrap">
          <!-- Principal -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary group flex-1 sm:flex-none justify-center inline-flex items-center gap-2 sm:gap-2.5
                 bg-[#1D9E75] hover:bg-[#188761] text-white font-semibold
                 px-4 py-3.5 sm:px-7 md:px-8 md:py-4 rounded-lg text-[13px] sm:text-sm md:text-base transition-all duration-300
                 hover:shadow-lg hover:shadow-emerald-500/25 hover:-translate-y-0.5 whitespace-nowrap"
          >
            <svg
              class="w-4 h-4 md:w-5 md:h-5 flex-shrink-0 group-hover:scale-110 transition-transform"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Hablemos
            <svg
              class="w-3.5 h-3.5 opacity-70 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <!-- Secundario -->
          <a
            href="#proyectos"
            class="group flex-1 sm:flex-none justify-center inline-flex items-center gap-1.5 sm:gap-2 text-slate-400 hover:text-white text-[13px] sm:text-sm md:text-base font-medium
                 border border-slate-800 hover:border-slate-600 px-4 py-3.5 sm:px-6 md:px-7 md:py-4 rounded-lg
                 transition-all duration-300 whitespace-nowrap"
          >
            Ver proyectos
            <svg
              class="w-3.5 h-3.5 opacity-70 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- BLOQUE 2: métricas de confianza -->
      <div class="animate-fade-in-up" style="animation-delay: 220ms;">
        <div
          class="grid grid-cols-3 gap-3 sm:gap-4 md:gap-5 text-sm sm:text-base"
        >
          <!-- Métrica 1 -->
          <div
            class="metric-card group relative flex items-center gap-3 sm:gap-4 md:gap-5 rounded-2xl border border-slate-800/70 px-3 sm:px-5 md:px-6 py-3 sm:py-4 md:py-6 overflow-hidden"
          >
            <span
              class="hidden sm:flex flex-shrink-0 w-11 h-11 md:w-14 md:h-14 rounded-full border border-[#1D9E75]/40 bg-[#1D9E75]/5 items-center justify-center text-[#1D9E75] shadow-[inset_0_0_12px_rgba(29,158,117,0.15)]"
              aria-hidden="true"
            >
              <svg
                class="w-5 h-5 md:w-7 md:h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 9l-4 3 4 3m8-6l4 3-4 3m-2-9l-4 12"></path>
              </svg>
            </span>
            <div class="flex flex-col">
              <span
                class="metric-value text-[#1D9E75] font-bold text-lg md:text-2xl leading-none mb-1"
                >+5</span
              >
              <span class="text-[11px] md:text-sm text-slate-400 leading-snug"
                >proyectos en producción</span
              >
            </div>
          </div>
          <!-- Métrica 2 -->
          <div
            class="metric-card group relative flex items-center gap-3 sm:gap-4 md:gap-5 rounded-2xl border border-slate-800/70 px-3 sm:px-5 md:px-6 py-3 sm:py-4 md:py-6 overflow-hidden"
          >
            <span
              class="hidden sm:flex flex-shrink-0 w-11 h-11 md:w-14 md:h-14 rounded-full border border-[#1D9E75]/40 bg-[#1D9E75]/5 items-center justify-center text-[#1D9E75] shadow-[inset_0_0_12px_rgba(29,158,117,0.15)]"
              aria-hidden="true"
            >
              <svg
                class="w-5 h-5 md:w-7 md:h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </span>
            <div class="flex flex-col">
              <span
                class="metric-value text-[#1D9E75] font-bold text-lg md:text-2xl leading-none mb-1"
                >7–14</span
              >
              <span class="text-[11px] md:text-sm text-slate-400 leading-snug"
                >días de entrega inicial</span
              >
            </div>
          </div>
          <!-- Métrica 3 -->
          <div
            class="metric-card group relative flex items-center gap-3 sm:gap-4 md:gap-5 rounded-2xl border border-slate-800/70 px-3 sm:px-5 md:px-6 py-3 sm:py-4 md:py-6 overflow-hidden"
          >
            <span
              class="hidden sm:flex flex-shrink-0 w-11 h-11 md:w-14 md:h-14 rounded-full border border-[#1D9E75]/40 bg-[#1D9E75]/5 items-center justify-center text-[#1D9E75] shadow-[inset_0_0_12px_rgba(29,158,117,0.15)]"
              aria-hidden="true"
            >
              <svg
                class="w-5 h-5 md:w-7 md:h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z"></path>
              </svg>
            </span>
            <div class="flex flex-col">
              <span
                class="metric-value text-[#1D9E75] font-bold text-lg md:text-2xl leading-none mb-1"
                >1er mes</span
              >
              <span class="text-[11px] md:text-sm text-slate-400 leading-snug"
                >soporte incluido</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- /wrapper bloques 1+2 -->

    <!-- Watermark DA (anclado al panel, no al bloque) -->
    <div
      class="watermark-da absolute -bottom-6 -right-2 text-[100px] sm:text-[140px] md:text-[220px] xl:text-[260px] font-black leading-none pointer-events-none select-none tracking-tighter z-0"
      aria-hidden="true"
    >
      DA
    </div>

    <!-- ── BLOQUE 3: identidad + índice + redes ── -->
    <div
      class="relative z-10 animate-fade-in-up"
      style="animation-delay: 380ms; padding-top: 0.75rem;"
    >
      <!-- Identidad: firma + nombre -->
      <div class="flex items-center gap-4 mb-1 md:mb-1.5">
        <!-- Firma manuscrita: iniciales DA -->
        <svg
          class="signature-svg hidden md:block flex-shrink-0 w-16 h-12 md:w-20 md:h-14 text-[#1D9E75]"
          viewBox="0 0 100 56"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M4 46 C 8 38, 12 26, 16 14 C 18 8, 22 6, 28 8 C 38 11, 44 22, 42 32 C 40 42, 30 46, 20 44 C 14 43, 12 38, 16 36 C 22 33, 30 36, 34 42"
          ></path>
          <path
            d="M48 44 C 52 30, 58 18, 64 14 C 68 12, 72 14, 72 22 L 72 44 C 72 48, 76 50, 82 46 C 88 42, 94 36, 96 30"
          ></path>
          <path d="M58 36 L 70 36"></path>
        </svg>
        <p
          class="text-lg md:text-xl font-semibold text-white tracking-tight leading-none"
        >
          Duván Apiolaza
        </p>
      </div>
      <div
        class="flex items-center justify-between gap-4 mb-2 md:mb-5 md:pl-[6rem]"
      >
        <p class="text-xs md:text-sm text-slate-500">
          Desarrollador web · Co-founder de LowSystem · Remoto en Chile
        </p>
        <!-- Redes sociales solo en desktop -->
        <div class="hidden md:flex items-center gap-2 flex-shrink-0">
          <a
            href="https://github.com/duvapi5"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-link flex items-center justify-center w-8 h-8 rounded-lg border border-slate-800 text-slate-400 hover:text-white hover:border-slate-600 transition-all duration-300"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/duvan-apiolaza/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-link flex items-center justify-center w-8 h-8 rounded-lg border border-slate-800 text-slate-400 hover:text-white hover:border-slate-600 transition-all duration-300"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="https://instagram.com/duvanapiolaza.cl"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="social-link flex items-center justify-center w-8 h-8 rounded-lg border border-slate-800 text-slate-400 hover:text-white hover:border-slate-600 transition-all duration-300"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
