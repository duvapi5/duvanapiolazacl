  "TensorFlow":   { icon: "https://cdn.simpleicons.org/tensorflow/FF6F00",   color: "#FF6F00" },
  "OpenCV":       { icon: "https://cdn.simpleicons.org/opencv/5C3EE8",       color: "#5C3EE8" },
  "Keras":        { icon: "https://cdn.simpleicons.org/keras/D00000",        color: "#D00000" },
