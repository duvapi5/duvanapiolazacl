---

<section id="proyectos" class="pt-20 pb-8 bg-slate-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute top-1/4 -right-32 w-96 h-96 bg-emerald-500/8 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -left-32 w-96 h-96 bg-cyan-500/8 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/3 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
    <!-- Header -->
    <div data-animate data-animation="fade-in-up" class="opacity-0">
      <div class="text-center mb-12 sm:mb-16">
        <span class="inline-block px-3 py-1 text-xs font-medium text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/20 mb-4 uppercase tracking-wider" data-i18n="projects.badge">
          Portafolio
        </span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
          <span data-i18n="projects.title">Proyectos</span> <span class="text-emerald-400" data-i18n="projects.titleHighlight">activos</span>
        </h2>
        <p class="text-slate-400 max-w-xl mx-auto" data-i18n="projects.subtitle">
          Sistemas funcionando en producción, resolviendo problemas concretos.
        </p>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, index) => (
        <div
          data-animate
          data-animation="fade-in-up"
          class:list={["opacity-0 h-full", project.featured && "md:col-span-2 lg:col-span-2"]}
          style={`animation-delay: ${(index + 1) * 100}ms;`}
        >
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col h-full rounded-2xl overflow-hidden bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 transition-all duration-500 hover:border-emerald-500/30 hover:-translate-y-1 hover:shadow-2xl hover:shadow-emerald-500/[0.05]"
          >
            <!-- Browser top bar -->
            <div class="flex items-center gap-2.5 px-4 py-2.5 bg-slate-900/80 border-b border-slate-700/30">
              <div class="flex gap-1.5 shrink-0">
                <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-red-400/70 transition-colors duration-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-yellow-400/70 transition-colors duration-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-green-400/70 transition-colors duration-300"></span>
              </div>
              <div class="flex-1 flex items-center gap-2 bg-slate-800/60 rounded-lg px-3 py-1 min-w-0">
                <svg class="w-3 h-3 text-emerald-500/50 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-[11px] text-slate-500 truncate font-mono">{project.urlLabel}</span>
              </div>
              <svg class="w-4 h-4 text-slate-600 group-hover:text-emerald-400 group-hover:rotate-[-8deg] transition-all duration-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>

            <!-- Project Hero / Screenshot -->
            <div
              class:list={[
                "relative overflow-hidden flex-1",
                project.featured ? "min-h-[16rem] md:min-h-[20rem]" : "min-h-[12rem]"
              ]}
            >
              <img
                src={project.image}
                alt={project.nameDefault}
                class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                loading={index === 0 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-slate-950/20 to-transparent"></div>

              <!-- Status badge on image -->
              <div class="absolute bottom-3 left-4">
                {project.statusType === "production" && (
                  <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-emerald-500/20 text-emerald-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                  </span>
                )}
                {project.statusType === "demo" && (
                  <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-amber-500/20 text-amber-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                  </span>
                )}
                {project.statusType === "academic" && (
                  <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-blue-500/20 text-blue-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                    <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                  </span>
                )}
              </div>
            </div>

            <!-- Content -->
            <div class="p-5">
              <h3 class="text-lg font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors duration-300" data-i18n={project.nameKey}>
                {project.nameDefault}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-4" data-i18n={project.descKey}>
                {project.descDefault}
              </p>

              <!-- Tech Stack -->
              <div class="flex flex-wrap gap-2">
                {project.techs.map((tech) => {
                  const t = techIcons[tech];
                  return (
                    <span
                      title={tech}
                      class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-slate-800/80 border border-slate-700/50 hover:border-slate-600/70 transition-colors duration-200"
                    >
                      {t ? (
                        <img src={t.icon} alt={tech} class="w-3.5 h-3.5 shrink-0" loading="lazy" />
                      ) : (
                        <span class="w-3.5 h-3.5 shrink-0 rounded-sm bg-slate-600/60"></span>
                      )}
                      <span class="text-[11px] text-slate-400 font-mono">{tech}</span>
                    </span>
                  );
                })}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Show More Toggle -->
    <div class="mt-8 text-center">
      <button
        id="toggle-more-btn"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-slate-400 hover:text-white border border-slate-700/50 hover:border-emerald-500/40 rounded-xl transition-all duration-300 bg-slate-900/40 hover:bg-slate-900/80 group"
      >
        <span id="label-show" data-i18n="projects.showMore">Más proyectos</span>
        <span id="label-hide" class="hidden" data-i18n="projects.showLess">Ver menos</span>
        <svg id="toggle-arrow" class="w-4 h-4 transition-transform duration-300 text-emerald-500/60 group-hover:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>

    <!-- Hidden / Extra Projects -->
    <div id="more-projects-grid" class="overflow-hidden transition-[max-height] duration-500 ease-in-out" style="max-height: 0;">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-5">
        {hiddenProjects.map((project, index) => (
          <div
            data-animate
            data-animation="fade-in-up"
            class="opacity-0 h-full"
            style={`animation-delay: ${(index + 1) * 100}ms;`}
          >
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col h-full rounded-2xl overflow-hidden bg-slate-900/60 backdrop-blur-sm border border-slate-700/50 transition-all duration-500 hover:border-emerald-500/30 hover:-translate-y-1 hover:shadow-2xl hover:shadow-emerald-500/[0.05]"
            >
              <div class="flex items-center gap-2.5 px-4 py-2.5 bg-slate-900/80 border-b border-slate-700/30">
                <div class="flex gap-1.5 shrink-0">
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-red-400/70 transition-colors duration-300"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-yellow-400/70 transition-colors duration-300"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-700 group-hover:bg-green-400/70 transition-colors duration-300"></span>
                </div>
                <div class="flex-1 flex items-center gap-2 bg-slate-800/60 rounded-lg px-3 py-1 min-w-0">
                  <svg class="w-3 h-3 text-emerald-500/50 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-[11px] text-slate-500 truncate font-mono">{project.urlLabel}</span>
                </div>
                <svg class="w-4 h-4 text-slate-600 group-hover:text-emerald-400 group-hover:rotate-[-8deg] transition-all duration-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              <div class="relative overflow-hidden flex-1 min-h-[12rem]">
                <img
                  src={project.image}
                  alt={project.nameDefault}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-slate-950/20 to-transparent"></div>
                <div class="absolute bottom-3 left-4">
                  {project.statusType === "production" && (
                    <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-emerald-500/20 text-emerald-400">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                      <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                    </span>
                  )}
                  {project.statusType === "demo" && (
                    <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-amber-500/20 text-amber-400">
                      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                      <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                    </span>
                  )}
                  {project.statusType === "academic" && (
                    <span class="inline-flex items-center gap-1.5 text-[10px] font-medium px-2.5 py-1 rounded-full bg-slate-900/70 backdrop-blur-sm border border-blue-500/20 text-blue-400">
                      <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                      <span data-i18n={project.statusKey}>{project.statusDefault}</span>
                    </span>
                  )}
                </div>
              </div>
              <div class="p-5">
                <h3 class="text-lg font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors duration-300" data-i18n={project.nameKey}>
                  {project.nameDefault}
                </h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-4" data-i18n={project.descKey}>
                  {project.descDefault}
                </p>
                <div class="flex flex-wrap gap-2">
                  {project.techs.map((tech) => {
                    const t = techIcons[tech];
                    return (
                      <span
                        title={tech}
                        class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-slate-800/80 border border-slate-700/50 hover:border-slate-600/70 transition-colors duration-200"
                      >
                        {t ? (
                          <img src={t.icon} alt={tech} class="w-3.5 h-3.5 shrink-0" loading="lazy" />
                        ) : (
                          <span class="w-3.5 h-3.5 shrink-0 rounded-sm bg-slate-600/60"></span>
                        )}
                        <span class="text-[11px] text-slate-400 font-mono">{tech}</span>
                      </span>
                    );
                  })}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- In Development Notice -->
    <div class="mt-10 flex items-center justify-center gap-3 text-slate-500 text-sm">
      <span class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
        </span>
        <span class="text-slate-400" data-i18n="projects.inDev">1 proyecto en etapa de validación</span>
      </span>
    </div>

    <!-- Narrative bridge -->
    <div data-animate data-animation="fade-in-up" class="opacity-0" style="animation-delay: 700ms;">
      <div class="mt-16 text-center">
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="w-12 h-px bg-gradient-to-r from-transparent to-slate-700"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-500/50"></div>
          <div class="w-12 h-px bg-gradient-to-l from-transparent to-slate-700"></div>
        </div>
        <p class="text-slate-400 text-sm" data-i18n="projects.bridge">
          Detrás de cada proyecto hay un proceso claro.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('toggle-more-btn');
  const grid = document.getElementById('more-projects-grid') as HTMLElement | null;
  const labelShow = document.getElementById('label-show');
  const labelHide = document.getElementById('label-hide');
  const arrow = document.getElementById('toggle-arrow');
  let expanded = false;

  btn?.addEventListener('click', () => {
    expanded = !expanded;
    if (grid) {
      grid.style.maxHeight = expanded ? grid.scrollHeight + 'px' : '0';
    }
    labelShow?.classList.toggle('hidden', expanded);
    labelHide?.classList.toggle('hidden', !expanded);
    arrow?.classList.toggle('rotate-180', expanded);
  });
</script>
