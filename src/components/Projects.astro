    descDefault: "Proyecto académico de visión computacional para GreenGuardian. Una CNN detecta enfermedades en plantas desde imágenes en tiempo real.",
    statusKey: "projects.p2.status",
    statusDefault: "Tesis de Titulación",
    statusType: "academic" as const,
    url: "https://www.linkedin.com/in/duvan-apiolaza/overlay/Education/1180212253/treasury/?profileId=ACoAAC-jBCYBwEG9AgcY1a8lqtpmrhE753jByqU",
    urlLabel: "linkedin.com · Tesis USM",
    image: "/og.png",
    techs: ["Python", "TensorFlow", "CNN", "OpenCV", "Keras"],
    featured: false,
