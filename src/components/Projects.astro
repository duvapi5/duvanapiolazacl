  "WhatsApp API": { icon: "https://cdn.simpleicons.org/whatsapp/25D366",     color: "#25D366" },
  "Arduino":      { icon: "https://cdn.simpleicons.org/arduino/00979D",      color: "#00979D" },
  "CNN":          { icon: "https://cdn.simpleicons.org/pytorch/EE4C2C",      color: "#EE4C2C" },
  "Icecast":      { icon: "https://api.iconify.design/mdi:radio-tower.svg?color=%23FF6600",  color: "#FF6600" },
  "AzuraCast":    { icon: "https://api.iconify.design/mdi:radio.svg?color=%230096FF",        color: "#0096FF" },
  "SvelteKit":    { icon: "https://cdn.simpleicons.org/svelte/FF3E00",                        color: "#FF3E00" },
  "Three.js":     { icon: "https://cdn.simpleicons.org/threedotjs/white",                     color: "#ffffff" },
