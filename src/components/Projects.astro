const projects = [
  {
    nameKey: "projects.p3.name",
    nameDefault: "Tu Impuesto",
    descKey: "projects.p3.desc",
    descDefault: "Plataforma SaaS tributaria para empresas. Automatiza declaraciones, centraliza documentos y acelera la operación fiscal.",
    statusKey: "projects.p3.status",
    statusDefault: "Producción",
    statusType: "production" as const,
    url: "https://tuimpuesto.cl",
    urlLabel: "tuimpuesto.cl",
    image: "/projects/tuimpuesto.jpg",
    techs: ["React", "Django", "PostgreSQL", "Redis", "Playwright", "Docker"],
    featured: true,
  },
  {
    nameKey: "projects.p5.name",
    nameDefault: "LowSystem",
    descKey: "projects.p5.desc",
    descDefault: "Landing corporativa para LowSystem. Comunica servicios de desarrollo, automatización y soluciones digitales para empresas.",
    statusKey: "projects.p5.status",
    statusDefault: "Producción",
    statusType: "production" as const,
    url: "https://lowsystem.cl",
    urlLabel: "lowsystem.cl",
    image: "/projects/lowsystem.jpg",
    techs: ["Astro", "Tailwind CSS", "Vercel"],
    featured: false,
  },
  {
    nameKey: "projects.p1.name",
    nameDefault: "Churrascas Las Delicias 101",
    descKey: "projects.p1.desc",
