    featured: false,
  },
  {
    nameKey: "projects.p4.name",
    nameDefault: "Peluquería Don Omar",
    descKey: "projects.p4.desc",
    descDefault: "Landing para Peluquería Don Omar. Presenta servicios, ubicación y reservas directas por WhatsApp.",
    statusKey: "projects.p4.status",
    statusDefault: "Producción",
    statusType: "production" as const,
    url: "https://peluqueriadonomar.cl",
    urlLabel: "peluqueriadonomar.cl",
    image: "/projects/peluqueriadonomar.jpg",
    techs: ["Astro", "Tailwind CSS", "WhatsApp", "Vercel"],
    featured: false,
  },
  {
    nameKey: "projects.p6.name",
    nameDefault: "Radio Auténtica",
    descKey: "projects.p6.desc",
    descDefault: "Plataforma web para Radio Auténtica. Streaming en vivo con integración Icecast y gestión en AzuraCast.",
    statusKey: "projects.p6.status",
    statusDefault: "Producción",
    statusType: "production" as const,
    url: "https://www.radioautentica.cl/",
    urlLabel: "radioautentica.cl",
    image: "/projects/radioautentica.jpg",
    techs: ["Icecast", "AzuraCast", "Docker", "Astro", "Tailwind CSS", "Vercel"],
    featured: false,
  },
];

const hiddenProjects = [
  {
    nameKey: "projects.p7.name",
    nameDefault: "Proyecto Zátira",
    descKey: "projects.p7.desc",
    descDefault: "Landing experimental para Zátira, productora de eventos electrónicos. Estética glitch, animaciones 3D y microinteracciones de inspiración nocturna.",
    statusKey: "projects.p7.status",
    statusDefault: "Producción",
    statusType: "production" as const,
    url: "https://proyectozatira.cl",
    urlLabel: "proyectozatira.cl",
    image: "/projects/proyectozatira.jpg",
    techs: ["SvelteKit", "TypeScript", "Three.js", "Tailwind CSS", "Redis", "Vercel"],
    featured: false,
  },
  {
