  "Next.js":      { icon: "https://cdn.simpleicons.org/nextdotjs/white",      color: "#ffffff" },
  "Node.js":      { icon: "https://cdn.simpleicons.org/nodedotjs/6DA55F",    color: "#6DA55F" },
  "Django":       { icon: "https://cdn.simpleicons.org/django/44B78B",       color: "#44B78B" },
  "PostgreSQL":   { icon: "https://cdn.simpleicons.org/postgresql/4169E1",   color: "#4169E1" },
  "Redis":        { icon: "https://cdn.simpleicons.org/redis/FF4438",        color: "#FF4438" },
  "Playwright":   { icon: "https://api.iconify.design/logos:playwright.svg",  color: "#45BA4B" },
